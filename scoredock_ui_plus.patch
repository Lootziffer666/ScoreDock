+/* --- UI polish additions (zero-dep) --- */
+
+/* Accessible focus rings */
+:where(a, button, input, select, textarea, [tabindex]):focus-visible{
+  outline: 3px solid color-mix(in srgb, var(--accent) 55%, transparent);
+  outline-offset: 2px;
+  border-radius: 12px;
+}
+
+/* Make links look like links (inherit still OK for nav) */
+a.link{ color: var(--accent); text-decoration: none; }
+a.link:hover{ text-decoration: underline; }
+
+/* Utilities: spacing + alignment */
+.gap-6{ gap:6px; } .gap-8{ gap:8px; } .gap-10{ gap:10px; } .gap-12{ gap:12px; } .gap-16{ gap:16px; }
+.mt-6{ margin-top:6px; } .mt-8{ margin-top:8px; } .mt-10{ margin-top:10px; } .mt-12{ margin-top:12px; }
+.jc-between{ justify-content: space-between; } .ai-start{ align-items:flex-start; } .wrap{ flex-wrap: wrap; }
+
+/* Card header pattern */
+.card-header{ display:flex; align-items:flex-start; justify-content:space-between; gap:12px; }
+.card-title{ display:flex; flex-direction:column; gap:4px; }
+.card-actions{ display:flex; align-items:center; gap:10px; flex-wrap:wrap; }
+
+/* Form field pattern */
+.field{ display:flex; flex-direction:column; gap:6px; min-width: 220px; }
+.label{ font-size:12px; color: var(--muted); }
+.help{ font-size:12px; color: color-mix(in srgb, var(--muted) 85%, transparent); line-height:1.4; }
+
+/* Notice / status */
+.notice{
+  padding: 10px 12px;
+  border-radius: 12px;
+  border: 1px solid var(--border);
+  background: color-mix(in srgb, var(--panel) 85%, transparent);
+  font-size: 13px;
+}
+.notice.good{ border-color: color-mix(in srgb, var(--good) 45%, var(--border)); }
+.notice.bad{ border-color: color-mix(in srgb, var(--bad) 45%, var(--border)); }
+.notice.warn{ border-color: color-mix(in srgb, var(--warn) 45%, var(--border)); }
+
+/* Buttons */
+.btn:disabled{ opacity: .55; cursor: not-allowed; }
+
+/* Link-like button for table rows etc */
+.linklike{
+  appearance:none;
+  background: transparent;
+  border: none;
+  padding: 0;
+  color: var(--accent);
+  cursor: pointer;
+  font: inherit;
+}
+.linklike:hover{ text-decoration: underline; }
+
+/* Table row affordances */
+.table tbody tr[data-job]{ cursor: pointer; }
+.table tbody tr[data-job]:hover{ background: color-mix(in srgb, var(--accent) 6%, transparent); }
+.table tr[aria-selected="true"]{
+  outline: 2px solid color-mix(in srgb, var(--accent) 45%, transparent);
+  outline-offset: -2px;
+  background: color-mix(in srgb, var(--accent) 8%, transparent);
+}
+
+/* Skip link */
+.skiplink{
+  position: absolute;
+  left: 12px;
+  top: 10px;
+  padding: 8px 10px;
+  border-radius: 12px;
+  border: 1px solid var(--border);
+  background: var(--panel);
+  color: var(--fg);
+  transform: translateY(-140%);
+  transition: transform 140ms ease;
+  z-index: 999;
+}
+.skiplink:focus{ transform: translateY(0); }
+
+/* Log viewer header */
+.logbar{
